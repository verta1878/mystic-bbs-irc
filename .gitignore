# Free Pascal compiler artifacts
*.ppu
*.o
*.a
*.exe
*.dll
*.so
*.dylib

# Build output directories
out/
outwin/
out386/
out_darwin/
bin/

# Compiler leftovers
link.res
ppas.sh
*.compiled
*.mpx

# Editor / OS cruft
*.bak
*.orig
*~
.DS_Store
Thumbs.db

# Add-on module generated / build files
modem.ini
mystic_modem/out/
mystic_modem/bin/
mystic_mailer/out/
mystic_mailer/bin/

# MIS running-lock semaphore
*.bsy

# add-on module build outputs
mystic_*/out/
mystic_*/bin/
mystic_*/out64/
mystic_*/bin64/
mystic_*/outwin/
mystic_*/binwin/

# but DO keep the runtime libraries placed under libs/ (any depth, incl.
# the win32/ and linux-i386/ platform subdirs)
!libs/**/*.dll
!libs/**/*.so
!libs/**/*.so.*
!libs/**/*.dylib
!libs/*.dll
!libs/*.so
!libs/*.so.*
!libs/*.dylib

# but DO keep the bundled Darwin ld64 cross-toolchain (see tools/darwin/)
!libs/ld64-linux-x86_64/
!libs/ld64-linux-x86_64/bin/
!libs/ld64-linux-x86_64/bin/*
!libs/ld64-linux-x86_64/lib/
!libs/ld64-linux-x86_64/lib/*
