 { COFF_SECTION_NAME_PARTIAL_MATCH (".gnu.linkonce.wi"), \
   COFF_ALIGNMENT_FIELD_EMPTY, COFF_ALIGNMENT_FIELD_EMPTY, 0 }
 
+/* FPC (Free Pascal) go32v2 output uses storage class 0x68 (C_SECTION) for
+   section symbols (.text/.data/.bss), the PE convention, rather than plain
+   COFF's C_LINE.  Enable C_SECTION handling in coffcode.h for this target so
+   GNU ld/nm/objdump can read FPC-produced objects (needed to link FPC DOS
+   programs against C libraries such as Watt-32).  */
+#define COFF_GO32_C_SECTION
+
