--- /tmp/pristine_bu/binutils-2.30/bfd/coffcode.h	2018-01-23 10:49:41.000000000 +0000
+++ bfd/coffcode.h	2026-07-09 19:55:24.619709049 +0000
@@ -4840,9 +4840,13 @@
 #ifdef C_SYSTEM
 	    case C_SYSTEM:	/* System Wide variable.  */
 #endif
-#ifdef COFF_WITH_PE
-	    /* In PE, 0x68 (104) denotes a section symbol.  */
+#if defined(COFF_WITH_PE) || defined(COFF_GO32_C_SECTION)
+	    /* In PE, 0x68 (104) denotes a section symbol.  FPC's go32v2
+	       output uses the same 0x68 = C_SECTION convention, so accept it
+	       for coff-go32 too (COFF_GO32_C_SECTION).  */
 	    case C_SECTION:
+#endif
+#ifdef COFF_WITH_PE
 	    /* In PE, 0x69 (105) denotes a weak external symbol.  */
 	    case C_NT_WEAK:
 #endif
@@ -5085,10 +5089,13 @@
 	    case C_EXTDEF:	/* External definition.  */
 	    case C_ULABEL:	/* Undefined label.  */
 	    case C_USTATIC:	/* Undefined static.  */
-#ifndef COFF_WITH_PE
-	    /* C_LINE in regular coff is 0x68.  NT has taken over this storage
-	       class to represent a section symbol.  */
+#if !defined(COFF_WITH_PE) && !defined(COFF_GO32_C_SECTION)
+	    /* C_LINE in regular coff is 0x68.  NT (and FPC's go32v2 output)
+	       have taken over this storage class to represent a section symbol,
+	       so with COFF_GO32_C_SECTION it is handled as C_SECTION above.  */
 	    case C_LINE:	/* line # reformatted as symbol table entry.  */
+#endif
+#ifndef COFF_WITH_PE
 	      /* NT uses 0x67 for a weak symbol, not C_ALIAS.  */
 	    case C_ALIAS:	/* Duplicate tag.  */
 #endif
